      Enabled: true
      Marker Topic: /robot3/text_marker_kuka
      Name: kuka3
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /robot2/text_marker_kuka
      Name: kuka2
      Namespaces:
        {}
